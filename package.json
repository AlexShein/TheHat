{
  "name": "thehat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:solo": "VITE_DEV_BYPASS_MIN_PLAYERS=true vite dev",
    "emulators": "firebase emulators:start --only database,functions",
    "dev:full": "concurrently \"npm run emulators\" \"npm run dev\"",
    "dev:solo:full": "concurrently \"npm run emulators\" \"npm run dev:solo\"",
    "test": "vitest run --coverage",
    "test:ci": "firebase emulators:exec --project=ci-test --only database 'vitest run --coverage'",
    "test:ci:auth": "firebase emulators:exec --project=ci-test --only database,auth 'vitest run --coverage'",
    "dev:bootstrap": "firebase emulators:exec --project=demo-bootstrap --only database,auth 'tsx scripts/dev-bootstrap.ts'",
    "test:rules": "firebase emulators:exec --project=ci-test --only database 'vitest run src/lib/rules.test.ts'",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "svelte-check && tsc --noEmit",
    "build": "vite build",
    "test:bundle": "MAX_KB=250; ACTUAL=$(du -sk build/_app/immutable/chunks/ 2>/dev/null | awk '{sum+=$1} END {print sum+0}'); echo \"Bundle: ${ACTUAL}KB (limit: ${MAX_KB}KB)\"; [ \"$ACTUAL\" -le \"$MAX_KB\" ] || (echo \"FAIL: ${ACTUAL}KB > ${MAX_KB}KB\" && exit 1)"
  },
  "dependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "firebase": "^11.0.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.0",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/typography": "^0.5.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^3.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^3.17.1",
    "firebase-admin": "^13.8.0",
    "firebase-tools": "^15.16.0",
    "postcss": "^8.4.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
