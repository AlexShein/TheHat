{
  "rules": {
    "admins": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid"
      },
      ".write": false
    },
    "rooms": {
      ".indexOn": ["meta/lastActiveAt"],
      "$roomId": {
        ".read": true,
        "meta": {
          ".write": "auth != null && root.child('admins').child(auth.uid).exists()",
          ".validate": "newData.hasChildren(['createdBy', 'createdAt', 'lastActiveAt'])"
        },
        "config": {
          ".write": "auth != null && root.child('admins').child(auth.uid).exists()",
          ".validate": "newData.hasChildren(['wordCount', 'numTeams', 'skipPenalty', 'timerDuration'])"
        },
        "players": {
          "$playerId": {
            ".write": "auth != null && (auth.uid === $playerId)",
            ".validate": "newData.hasChildren(['name', 'color', 'wordsSubmitted', 'ready', 'connected', 'isAdmin'])"
          }
        },
        "teams": {
          "$teamId": {
            ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || root.child('rooms').child($roomId).child('meta').child('createdBy').val() === auth.uid)"
          }
        },
        "words": {
          "$wordId": {
            ".write": "auth != null",
            ".validate": "newData.hasChildren(['text', 'addedBy'])"
          }
        },
        "gameState": {
          ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || root.child('rooms').child($roomId).child('meta').child('createdBy').val() === auth.uid)"
        },
        "status": {
          ".write": "auth != null && (root.child('admins').child(auth.uid).exists() || root.child('rooms').child($roomId).child('meta').child('createdBy').val() === auth.uid)",
          ".validate": "newData.isString() && (newData.val() === 'word-entry' || newData.val() === 'pre-start' || newData.val() === 'playing' || newData.val() === 'finished')"
        }
      }
    }
  }
}
